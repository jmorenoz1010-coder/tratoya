# ================================================
# TRATOYA FRONTEND — Variables de entorno
# Para desarrollo local: copia como .env
# Para producción: configura en Vercel dashboard
#   → Settings → Environment Variables
# ================================================

# URL del backend
# Local: http://localhost:4000/api
# Producción: https://tratoya-backend.up.railway.app/api
VITE_API_URL=http://localhost:4000/api

# Pago manual verificado
# Puedes subir el QR real a /public o usar una URL publica. Si queda vacio, se genera QR con la llave.
VITE_MANUAL_PAYMENT_QR_URL=
VITE_MANUAL_PAYMENT_KEY=soporte@tratoya.com
VITE_MANUAL_PAYMENT_NAME=TratoYa
