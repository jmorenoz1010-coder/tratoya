# ================================================
# TRATOYA BACKEND — Variables de entorno
# Para desarrollo local: copia como .env
# Para producción: configura en Railway dashboard
# ================================================

# ─── SERVIDOR ──────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=https://tratoya.com
BACKEND_URL=https://api.tratoya.com
CORS_ALLOWED_ORIGINS=https://tratoya.com,https://www.tratoya.com

# ─── BASE DE DATOS ─────────────────────────────
# Local:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tratoya_db
DB_USER=tratoya_user
DB_PASSWORD=tratoya_password_2026
DB_SSL=false
DATABASE_URL=postgresql://tratoya_user:tratoya_password_2026@localhost:5432/tratoya_db
# Producción (Neon/Railway): solo usar DATABASE_URL con ?sslmode=require y DB_SSL=true
# DB_SYNC=true en dev (alter automático), false en producción
DB_SYNC=true

# ─── REDIS ─────────────────────────────────────
# Local: redis://localhost:6379
# Producción (Upstash): rediss://default:TOKEN@host.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_clave_aleatoria_de_64_caracteres_minimo
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=cambia_esto_por_otra_clave_diferente_de_64_caracteres
JWT_REFRESH_EXPIRES_IN=30d

# ─── ADMIN INICIAL ─────────────────────────────
ADMIN_EMAIL=admin@tratoya.co
ADMIN_PASSWORD=CambiaEstoEnProduccion123!
ADMIN_NAME=Admin
ADMIN_LASTNAME=TratoYA
ADMIN_CEDULA=
ADMIN_CITY=Bogota
ADMIN_ROLE=superadmin
# false después del primer boot para no resetear password en cada reinicio
ADMIN_RESET_ON_BOOT=false

# ─── PAGOS (flags) ─────────────────────────────
PAYMENTS_MODE=manual

# ─── COMISIONES ────────────────────────────────
COMMISSION_MIN_FEE=1500
COMMISSION_MIN_AMOUNT=50000

# ─── TWILIO (SMS, opcional) ────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── SENTRY (monitoreo de errores, opcional) ───
# Obtén el DSN en sentry.io → Settings → Projects → Client Keys
SENTRY_DSN=
