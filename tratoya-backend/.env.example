# ================================================
# TRATOYA BACKEND — Variables de entorno
# Copia este archivo como .env y llena los valores
# ================================================

NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
DB_SYNC=true

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tratoya_db
DB_USER=tratoya_user
DB_PASSWORD=tratoya_password_2026
DB_SSL=false
DATABASE_URL=postgresql://tratoya_user:tratoya_password_2026@localhost:5432/tratoya_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT — genera claves con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_clave_aleatoria_de_64_caracteres_minimo
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=cambia_esto_por_otra_clave_diferente_de_64_caracteres
JWT_REFRESH_EXPIRES_IN=30d

# Admin inicial para ambientes nuevos
ADMIN_EMAIL=admin@tratoya.com
ADMIN_PASSWORD=cambia_esta_contrasena_en_produccion
ADMIN_NAME=Admin
ADMIN_LASTNAME=TratoYA
ADMIN_ROLE=superadmin
ADMIN_RESET_ON_BOOT=false

# Wompi
# Sandbox: WOMPI_ENV=sandbox y WOMPI_PUBLIC_KEY=pub_test_...
# Producción real: WOMPI_ENV=production y WOMPI_PUBLIC_KEY=pub_prod_...
WOMPI_ENV=sandbox
WOMPI_PUBLIC_KEY=pub_test_XXXXXXXXXXXXXXXX
WOMPI_PRIVATE_KEY=prv_test_XXXXXXXXXXXXXXXX
WOMPI_INTEGRITY_SECRET=test_integrity_XXXXXXXX
WOMPI_INTEGRITY_KEY=test_integrity_XXXXXXXX
WOMPI_EVENTS_SECRET=cualquier_texto_secreto
WOMPI_BASE_URL=https://sandbox.wompi.co/v1
BACKEND_URL=http://localhost:4000
PAYMENTS_REAL_ENABLED=false
PAYMENTS_MAX_TEST_AMOUNT_COP=50000
BETA_ALLOW_SANDBOX_PAYMENTS=true

# Comisiones
COMMISSION_MIN_FEE=1500
COMMISSION_MIN_AMOUNT=50000
