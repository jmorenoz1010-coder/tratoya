# ================================================
# TRATOYA BACKEND — Variables de entorno
# Para desarrollo local: copia como .env
# Para producción: configura en Railway dashboard
# ================================================

# ─── SERVIDOR ──────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=https://tratoya.com
BACKEND_URL=https://api.tratoya.com
CORS_ALLOWED_ORIGINS=https://tratoya.com,https://www.tratoya.com

# ─── BASE DE DATOS ─────────────────────────────
# Local:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tratoya_db
DB_USER=tratoya_user
DB_PASSWORD=tratoya_password_2026
DB_SSL=false
DATABASE_URL=postgresql://tratoya_user:tratoya_password_2026@localhost:5432/tratoya_db
# Producción (Neon/Railway): solo usar DATABASE_URL con ?sslmode=require y DB_SSL=true
# DB_SYNC=true en dev (alter automático), false en producción
DB_SYNC=true

# ─── REDIS ─────────────────────────────────────
# Local: redis://localhost:6379
# Producción (Upstash): rediss://default:TOKEN@host.upstash.io:6379
# Obligatorio en Vercel serverless para rate limiting efectivo entre instancias.
REDIS_URL=redis://localhost:6379
REDIS_REQUIRED=false

# Secreto para URLs firmadas de archivos (opcional; usa JWT_SECRET si no se define)
FILE_ACCESS_SECRET=

# ─── JWT ───────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_clave_aleatoria_de_64_caracteres_minimo
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=cambia_esto_por_otra_clave_diferente_de_64_caracteres
JWT_REFRESH_EXPIRES_IN=30d

# ─── ADMIN INICIAL ─────────────────────────────
ADMIN_EMAIL=admin@tratoya.co
ADMIN_PASSWORD=CambiaEstoEnProduccion123!
ADMIN_NAME=Admin
ADMIN_LASTNAME=TratoYA
ADMIN_CEDULA=
ADMIN_CITY=Bogota
ADMIN_ROLE=superadmin
# false después del primer boot para no resetear password en cada reinicio
ADMIN_RESET_ON_BOOT=false

# ─── PAGOS (flags) ─────────────────────────────
PAYMENTS_MODE=manual

# ─── COMISIONES ────────────────────────────────
COMMISSION_MIN_FEE=1500
COMMISSION_MIN_AMOUNT=50000

# ─── EMAIL (Brevo — 300 emails/día GRATIS para siempre) ────────
# 1. Regístrate en brevo.com (sin tarjeta)
# 2. Ve a Settings → SMTP & API → SMTP Keys → Generate
# 3. Copia las credenciales aquí
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=tu@email.com
SMTP_PASS=xsmtp-XXXXXXXXXXXXXXXXXX
EMAIL_FROM=TratoYA <soporte@tratoya.com>

# Alternativa rápida para testing (Gmail):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx  ← Contraseña de aplicación de Google

# ─── WHATSAPP (Meta Cloud API — 1,000 conversaciones/mes GRATIS) ─
# Setup (10 min): developers.facebook.com → My Apps → WhatsApp → Getting Started
# 1. Crea una app de tipo Business
# 2. Agrega el producto WhatsApp
# 3. Copia Phone Number ID y Access Token
# 4. Para producción: crea un System User con token permanente
# 5. Agrega WA_VERIFY_TOKEN (string aleatorio) para el webhook
WA_PHONE_NUMBER_ID=TU_PHONE_NUMBER_ID
WA_ACCESS_TOKEN=TU_ACCESS_TOKEN_META
WA_VERIFY_TOKEN=tratoya-webhook-secret-2026
WA_USE_TEMPLATES=true
WA_TEMPLATE_LANGUAGE=es_CO
WA_TEMPLATE_PREFIX=tratoya_
# Seguimiento de estado del trato por WhatsApp: con UN solo template aprobado
# en Meta llamado "tratoya_estado_trato" (5 variables, en este orden:
# {{1}} nombre, {{2}} codigo, {{3}} estado, {{4}} paso, {{5}} url) se cubre todo
# el ciclo del trato (aceptado, pago en verificación, pago protegido, en entrega,
# confirmado, completado). Ejemplo de cuerpo del template:
#   Hola {{1}}, tu trato {{2}}. Estado actual: {{3}}. Tu próximo paso: {{4}}. {{5}}
ADMIN_DELETE_USER_CODE=071020
# Vercel project root: tratoya-backend
# URL del webhook a registrar en Meta:
# https://api.tratoya.com/api/webhooks/whatsapp

# ─── TWILIO (SMS, opcional — $15 USD trial ≈ 1,875 SMS) ────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── SENTRY (monitoreo de errores, opcional) ───
SENTRY_DSN=

# --- Lista de espera pre-lanzamiento ---
WAITLIST_ADMIN_KEY=clave-secreta-para-admin
